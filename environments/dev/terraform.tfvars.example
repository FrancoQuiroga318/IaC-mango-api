# environments/prod/terraform.tfvars.example

# --- Red --------------------------------------------------------------------
vpc_cidr             = "10.0.0.0/16"
public_subnet_cidrs  = ["10.0.1.0/24", "10.0.2.0/24"]
private_subnet_cidrs = ["10.0.11.0/24", "10.0.12.0/24"]

# --- RDS existente ----------------------------------------------------------
rds_security_group_id = "sg-xxxxxxxxxxxxxxxxx"

# --- ACM --------------------------------------------------------------------
acm_certificate_arn = "arn:aws:acm:us-east-1:123456789012:certificate/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"

# --- Dominios ---------------------------------------------------------------
api_domain   = "api-dev.mango.com"
admin_domain = "admin-dev.mango.com"

# CIDRs para restringir mango-admin (dejar vacío para acceso público):
# admin_allowed_cidrs = ["203.0.113.10/32", "203.0.113.20/32"]
admin_allowed_cidrs = []

# --- Contenedor -------------------------------------------------------------
api_container_port      = 80
admin_container_port    = 80
api_health_check_path   = "/health"
admin_health_check_path = "/health"
image_tag               = "latest"

# --- SQS --------------------------------------------------------------------
create_sqs_queues = true

# --- Variables de entorno ---------------------------------------------------
api_environment_vars = [
  { name = "APP_ENV",  value = "local" },
  { name = "APP_PORT", value = "80" },
  { name = "QUEUE_CONNECTION", value = "sqs" },
]

# Secrets desde SSM Parameter Store:
api_secrets = [
  { name = "APP_KEY",       valueFrom = "arn:aws:ssm:us-east-1:123456789012:parameter/mango/dev/api/APP_KEY" },
  { name = "DB_PASSWORD",   valueFrom = "arn:aws:ssm:us-east-1:123456789012:parameter/mango/dev/api/DB_PASSWORD" },
]

admin_environment_vars = [
  { name = "APP_ENV",  value = "local" },
  { name = "APP_PORT", value = "80" },
  { name = "QUEUE_CONNECTION", value = "sqs" },
]

admin_secrets = [
  { name = "APP_KEY",       valueFrom = "arn:aws:ssm:us-east-1:123456789012:parameter/mango/dev/admin/APP_KEY" },
  { name = "DB_PASSWORD",   valueFrom = "arn:aws:ssm:us-east-1:123456789012:parameter/mango/dev/admin/DB_PASSWORD" },
]

// EJEMPLO
container = [
  { name = "admin",       cpu = 0.25, port = 80},
  { name = "cron",   valueFrom = "arn:aws:ssm:us-east-1:123456789012:parameter/mango/dev/admin/DB_PASSWORD" },
]